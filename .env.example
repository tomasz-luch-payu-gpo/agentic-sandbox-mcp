# Copy to .env and fill in your values

# Transport mode for docker-compose ("http" for persistent server, "stdio" for docker run)
MCP_TRANSPORT=http

# HTTP port (HTTP transport only)
PORT=3000

# Optional bearer token to protect the HTTP endpoint
# AUTH_TOKEN=supersecret

# Self-hosted GitLab base URL
# GITLAB_URL=https://gitlab.mycompany.com

# GitLab Personal Access Token (api + read_repository + write_repository scopes)
# GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Git identity used for commits inside the container
GIT_EMAIL=me@example.com
GIT_USER=My Name
